# 服务端 Embedding 配置（也可在项目根目录 .env.local 中配置）
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# 允许的前端域名（逗号分隔）。留空则允许所有来源（开发/mock 默认）
# 示例：https://your-site.netlify.app,http://localhost:5173
FRONTEND_ORIGIN=

# 监听地址（云托管默认 0.0.0.0，一般无需改）
HOST=0.0.0.0
